{
    "base_url": "https://v3.openstates.org",
    "auth": {
        "type": "api_key",
        "header": "X-API-KEY",
        "query_param": "apikey"
    },

    "endpoints": {
        "jurisdictions": {
            "list": {
                "path": "/jurisdictions",
                "method": "GET",
                "description": "List all supported jurisdictions.",
                "query_parameters": {
                    "classification": "",
                    "include": "",
                    "page": "",
                    "per_page": ""
                }
            },
            "detail": {
                "path": "/jurisdictions/{jurisdiction_id}",
                "method": "GET",
                "description": "Retrieve metadata for a single jurisdiction.",
                "path_parameters": {
                    "jurisdiction_id": ""
                }
            }
        },
        "people": {
            "list": {
                "path": "/people",
                "method": "GET",
                "description": "Search or list people (legislators, governors, etc.).",
                "query_parameters": {
                    "jurisdiction": "",
                    "name": "",
                    "party": "",
                    "chamber": "",
                    "classification": "",
                    "updated_since": "",
                    "include": "",
                    "page": "",
                    "per_page": ""
                }
            },
            "geo": {
                "path": "/people.geo",
                "method": "GET",
                "description": "Find legislators representing a geographic point.",
                "query_parameters": {
                    "lat": "float",
                    "lng": "float"
                }
            },
            "detail": {
                "path": "/people/{person_id}",
                "method": "GET",
                "description": "Retrieve detailed information for a person.",
                "path_parameters": {
                    "person_id": ""
                }
            }
        },
        "bills": {
            "search": {
                "path": "/bills",
                "method": "GET",
                "description": "Search bills by keyword, sponsor, subject, and status.",
                "query_parameters": {
                    "jurisdiction": "",
                    "session": "",
                    "identifier": "",
                    "q": "",
                    "subject": "",
                    "sponsor": "",
                    "classification": "",
                    "updated_since": "",
                    "sort": "",
                    "page": "",
                    "per_page": ""
                }
            },
            "detail": {
                "path": "/bills/{bill_id}",
                "method": "GET",
                "description": "Retrieve full bill details by internal ID.",
                "path_parameters": {
                    "bill_id": ""
                }
            }
        },
        "committees": {
            "list": {
                "path": "/committees",
                "method": "GET",
                "description": "List legislative committees.",
                "query_parameters": {
                    "jurisdiction": "",
                    "chamber": "",
                    "classification": "",
                    "page": "",
                    "per_page": ""
                }
            },
            "detail": {
                "path": "/committees/{committee_id}",
                "method": "GET",
                "description": "Retrieve committee details.",
                "path_parameters": {
                    "committee_id": ""
                }
            }
        },
        "events": {
            "list": {
                "path": "/events",
                "method": "GET",
                "description": "List legislative events (hearings, sessions, etc.).",
                "query_parameters": {
                    "jurisdiction": "",
                    "type": "",
                    "start_date": "",
                    "end_date": "",
                    "page": "",
                    "per_page": ""
                }
            },
            "detail": {
                "path": "/events/{event_id}",
                "method": "GET",
                "description": "Retrieve details for a specific event.",
                "path_parameters": {
                    "event_id": ""
                }
            }
        }
    }
}
